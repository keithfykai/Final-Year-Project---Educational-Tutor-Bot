rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Learning profile: read and write only by the owning user
      match /profile/main {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Chat sessions
      match /chatSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }

      // Quiz history
      match /quizHistory/{quizId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Topic progress
      match /topicProgress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Curriculum data is read-only for authenticated users; writes via Admin SDK only
    match /topicCurriculum/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
